{
  "name": "worker",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "format": "prettier --config ../prettier.config.bottomlessmargaritas.js --write .",
    "format:check": "prettier --config ../prettier.config.bottomlessmargaritas.js --check .",
    "lint": "eslint --config ../eslint.config.bottomlessmargaritas.js .",
    "lint:fix": "eslint --config ../eslint.config.bottomlessmargaritas.js . --fix",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@extractus/article-extractor": "^8.0.14",
    "@google-cloud/secret-manager": "^6.1.1",
    "bullmq": "^5.34.8",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.1",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^3.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^17.3.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "vitest": "^3.2.4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
