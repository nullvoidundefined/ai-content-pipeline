{
  "name": "ai-content-pipeline",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "build": "pnpm --filter server build && pnpm --filter worker build && pnpm --filter web-client build",
    "lint": "eslint --config eslint.config.bottomlessmargaritas.js .",
    "lint:fix": "eslint --config eslint.config.bottomlessmargaritas.js . --fix",
    "format": "prettier --config prettier.config.bottomlessmargaritas.js --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --config prettier.config.bottomlessmargaritas.js --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "test": "pnpm --filter server run test && pnpm --filter worker run test",
    "test:coverage": "pnpm --filter server run test:coverage && pnpm --filter worker run test:coverage"
  },
  "devDependencies": {
    "@bottomlessmargaritas/claude-architecture-prompts": "^2.1.0",
    "@bottomlessmargaritas/formatting-configs": "^2.1.0",
    "@trivago/prettier-plugin-sort-imports": "^4",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10",
    "eslint-plugin-security": "^3",
    "eslint-plugin-unused-imports": "^4",
    "globals": "^15",
    "prettier": "^3",
    "typescript-eslint": "^8"
  }
}
