{
  "name": "ai-content-pipeline",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "build": "pnpm --filter server build && pnpm --filter worker build && pnpm --filter web-client build",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "pnpm -r run format",
    "format:check": "pnpm -r run format:check",
    "test": "pnpm --filter server run test",
    "test:coverage": "pnpm --filter server run test:coverage"
  }
}
